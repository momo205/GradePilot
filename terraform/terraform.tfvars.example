# Example only — copy to `terraform.tfvars` (gitignored) and fill in real values.
# Do not commit real secrets.

project_id = "your-gcp-project-id"
region     = "northamerica-northeast1"

github_repository = "your-github-username-or-org/GradePilot"

artifact_registry_repo = "gradepilot"

api_image = "northamerica-northeast1-docker.pkg.dev/your-gcp-project-id/gradepilot/api:bootstrap"
web_image = "northamerica-northeast1-docker.pkg.dev/your-gcp-project-id/gradepilot/web:bootstrap"

supabase_url = "https://YOUR_PROJECT.supabase.co"
database_url = "postgresql://USER:PASSWORD@HOST:5432/postgres"

google_api_key             = ""
google_oauth_client_id     = ""
google_oauth_client_secret = ""
google_oauth_redirect_uri  = ""

frontend_supabase_url      = "https://YOUR_PROJECT.supabase.co"
frontend_supabase_anon_key = "YOUR_SUPABASE_ANON_KEY"
